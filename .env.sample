# ─────────────────────────────────────────────
#  Pi Agent — Provider API Keys Sample
#  Copy to .env and fill in your keys
#  Auto-loaded from multi-agents/.env by multi-team.ts and mcp-bridge.ts
#  Optional override: PI_ENV_FILE=relative/path/to/.env
# ─────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GEMINI_API_KEY=AIza...

# OpenRouter
OPENROUTER_API_KEY=sk-or-...

# Firecrawl (used by pi-pi expert agents for web crawling)
FIRECRAWL_API_KEY=fc-...

# Brave Search MCP
BRAVE_API_KEY=BSA...

# ─────────────────────────────────────────────
# Claude Code Router (CCR) integration (optional)
# ─────────────────────────────────────────────

# Inject <CCR-SUBAGENT-MODEL>provider,model</CCR-SUBAGENT-MODEL> into delegated child prompts
# PI_MULTI_CCR_SUBAGENT_ROUTING=1

# Optional fixed CCR subagent model override:
# accepts provider,model or provider/model
# PI_MULTI_CCR_SUBAGENT_MODEL=openrouter,anthropic/claude-sonnet-4

# Optional routing policy propagated in <PI-MULTI-ROUTE> (e.g. economy|balanced|quality|latency)
# PI_MULTI_CCR_POLICY=balanced

# By default, CCR mode skips child --model unless PI_MULTI_CCR_KEEP_CHILD_MODEL_ARG=1
# PI_MULTI_CCR_DISABLE_CHILD_MODEL_ARG=1
# PI_MULTI_CCR_KEEP_CHILD_MODEL_ARG=0
